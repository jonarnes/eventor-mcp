# Required: secret API key from your Eventor organisation settings (long hex / GUID string).
EVENTOR_API_KEY=

# Base URL (Norway default)
EVENTOR_BASE_URL=https://eventor.orientering.no

# Name of the HTTP header that carries the key — usually the word ApiKey, NOT the key value.
# See the Eventor API PDF guide if your federation documents a different header.
EVENTOR_API_KEY_HEADER=ApiKey

# HTTP timeouts (seconds)
EVENTOR_TIMEOUT_SECONDS=30.0

# Response cache (reduces repeated calls)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=256

# Logging
LOG_LEVEL=INFO
LOG_DIR=
LOG_ROTATION_WHEN=midnight
LOG_BACKUP_COUNT=14

# Statistics / summary tool guardrails
STATS_MAX_DATE_RANGE_DAYS=730
STATS_MAX_EVENTS_IN_SUMMARY=500
